{
  "name": "@landstrip/landstrip",
  "version": "0.17.20",
  "description": "Sandbox runner using Landlock, Seatbelt, and AppContainer",
  "license": "Apache-2.0 AND LGPL-2.1-or-later",
  "homepage": "https://github.com/landstrip/landstrip#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/landstrip/landstrip.git"
  },
  "bugs": {
    "url": "https://github.com/landstrip/landstrip/issues"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "bin": {
    "landstrip": "bin/landstrip.js"
  },
  "files": [
    "bin",
    "lib",
    "README.md",
    "LICENSE-APACHE-2.0",
    "LICENSE-LGPL-2.1"
  ],
  "optionalDependencies": {
    "@landstrip/landstrip-darwin-arm64": "0.17.20",
    "@landstrip/landstrip-darwin-x64": "0.17.20",
    "@landstrip/landstrip-linux-x64": "0.17.20",
    "@landstrip/landstrip-linux-arm64": "0.17.20",
    "@landstrip/landstrip-win32-x64": "0.17.20",
    "@landstrip/landstrip-win32-arm64": "0.17.20"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "ci:extensions": "scripts/test-extensions.sh",
    "ci:extensions:local": "scripts/test-extensions.sh --local-root"
  }
}
