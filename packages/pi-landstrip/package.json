{
  "name": "pi-landstrip",
  "version": "0.17.29",
  "description": "Sandbox-aware Pi subagents and interactive command permissions",
  "keywords": [
    "landstrip",
    "pi-extension",
    "pi-package",
    "sandbox",
    "subagents"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/landstrip/landstrip.git"
  },
  "files": [
    "api.ts",
    "agents.ts",
    "box.ts",
    "config.ts",
    "index.ts",
    "rpc-process.ts",
    "subagents.ts",
    "util.ts",
    "README.md",
    "subagents.json",
    "sandbox.json"
  ],
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./api": "./api.ts",
    "./*": "./*"
  },
  "scripts": {
    "fmt": "oxfmt *.ts package.json tsconfig.json subagents.json sandbox.json .oxfmtrc.json README.md",
    "lint": "oxlint *.ts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "all": "npm run fmt && npm run lint && npm run check && npm run test",
    "ci:fmt": "oxfmt --check *.ts package.json tsconfig.json subagents.json sandbox.json .oxfmtrc.json README.md",
    "ci:lint": "npm run lint",
    "ci:check": "npm run check",
    "ci:test": "npm run test"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.80.6",
    "@landstrip/landstrip": "^0.17.29",
    "minimatch": "^10.2.5"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@types/node": "^24.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.68.0",
    "typebox": "^1.3.6",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "typebox": "^1.3.6"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
